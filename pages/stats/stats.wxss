.container {
  display: flex;
  flex-direction: column;
  padding: 60rpx 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.glass {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
}

.stats-header {
  margin-bottom: 60rpx;
}

.stats-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 6rpx;
  display: block;
}

.stats-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 10rpx;
  display: block;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30rpx;
}

.stats-item {
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  min-height: 250rpx;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.stats-value-box {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.value {
  font-size: 56rpx;
  font-weight: bold;
  color: #00f2ff;
  text-shadow: 0 0 15rpx rgba(0, 242, 255, 0.3);
}

.highlight-purple {
  color: #ff00ff;
  text-shadow: 0 0 15rpx rgba(255, 0, 255, 0.3);
}

.unit {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.3);
  margin-left: 10rpx;
  letter-spacing: 2rpx;
}

.stats-progress-bar {
  width: 100%;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 2rpx;
  overflow: hidden;
}

.progress {
  height: 100%;
  background: #00f2ff;
  box-shadow: 0 0 10rpx #00f2ff;
}

.progress.purple {
  background: #ff00ff;
  box-shadow: 0 0 10rpx #ff00ff;
}

.stats-hint {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.2);
  margin-top: auto;
}
