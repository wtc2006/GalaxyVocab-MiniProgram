.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.glass {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
}

/* 顶部签到卡片 */
.header-card {
  width: 100%;
  display: flex;
  align-items: center;
  padding: 40rpx;
  margin-bottom: 60rpx;
  box-sizing: border-box;
}

.date-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 120rpx;
}

.day {
  font-size: 64rpx;
  font-weight: bold;
  color: #00f2ff;
  line-height: 1;
}

.month {
  font-size: 24rpx;
  color: rgba(0, 242, 255, 0.6);
  letter-spacing: 4rpx;
  margin-top: 10rpx;
}

.divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  margin: 0 40rpx;
}

.checkin-section {
  flex: 1;
}

.checkin-btn {
  padding: 20rpx;
  text-align: center;
  border-radius: 15rpx;
  border: 1px solid rgba(0, 242, 255, 0.3);
  transition: all 0.3s ease;
}

.checkin-btn text {
  font-size: 22rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  color: #00f2ff;
}

.checkin-btn.checked {
  background: rgba(0, 242, 255, 0.1);
  border-color: #00f2ff;
}

.checkin-btn.checked text {
  color: #00f2ff;
}

/* 任务网格 */
.task-grid {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.task-card {
  width: 100%;
  padding: 50rpx 40rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.task-card:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.08);
}

.task-icon {
  font-size: 60rpx;
  margin-right: 40rpx;
}

.task-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.task-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.task-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 8rpx;
  line-height: 1.5;
}

.task-badge {
  font-size: 48rpx;
  font-weight: bold;
  color: #00f2ff;
  text-shadow: 0 0 10rpx rgba(0, 242, 255, 0.5);
}

.review .task-badge {
  color: #ff00ff;
  text-shadow: 0 0 10rpx rgba(255, 0, 255, 0.5);
}

.review {
  border-color: rgba(255, 0, 255, 0.2);
}
