/**app.wxss**/
page {
  background-color: #050505;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  height: 100%;
}

.blob-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  overflow: hidden;
}

.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.3;
}

.blob-purple {
  width: 600rpx;
  height: 600rpx;
  background: #6a0dad;
  top: -100rpx;
  right: -100rpx;
  animation: movePurple 20s infinite alternate;
}

.blob-blue {
  width: 700rpx;
  height: 700rpx;
  background: #00008b;
  bottom: -150rpx;
  left: -150rpx;
  animation: moveBlue 25s infinite alternate;
}

@keyframes movePurple {
  0% { transform: translate(0, 0); }
  100% { transform: translate(-200rpx, 300rpx); }
}

@keyframes moveBlue {
  0% { transform: translate(0, 0); }
  100% { transform: translate(300rpx, -200rpx); }
}
